---
whiskers:
  version: "^2.5.1"
  filename: "flags.json"
  hex_format: "#{{r}}{{g}}{{b}}"
---
{
  {%- for id, flavor in flavors %}
  "{{id}}": {
    "aroace": [
      "{{flavor.colors.peach.hex}}",
      "{{flavor.colors.yellow.hex}}",
      "{{if(cond=flavor.light, t=flavor.colors.crust.hex, f=flavor.colors.text.hex)}}",
      "{{flavor.colors.sky.hex}}",
      "{{flavor.colors.blue.hex}}"
    ],
    "aromantic": [
      "{{flavor.colors.green.hex}}",
      "{{flavor.colors.teal.hex}}",
      "{{if(cond=flavor.light, t=flavor.colors.crust.hex, f=flavor.colors.text.hex)}}",
      "{{flavor.colors.overlay0.hex}}",
      "{{if(cond=flavor.light, t=flavor.colors.text.hex, f=flavor.colors.crust.hex)}}"
    ],
    "asexual": [
      "{{if(cond=flavor.light, t=flavor.colors.text.hex, f=flavor.colors.crust.hex)}}",
      "{{flavor.colors.overlay0.hex}}",
      "{{if(cond=flavor.light, t=flavor.colors.crust.hex, f=flavor.colors.text.hex)}}",
      "{{flavor.colors.mauve.hex}}"
    ],
    "bisexual": [
      "{{flavor.colors.pink.hex}}",
      "{{flavor.colors.pink.hex}}",
      "{{flavor.colors.mauve.hex}}",
      "{{flavor.colors.blue.hex}}",
      "{{flavor.colors.blue.hex}}"
    ],
    "lesbian": [
      "{{flavor.colors.peach.hex}}",
      "{{flavor.colors.yellow.hex}}",
      "{{if(cond=flavor.light, t=flavor.colors.crust.hex, f=flavor.colors.text.hex)}}",
      "{{flavor.colors.maroon.hex}}",
      "{{flavor.colors.red.hex}}"
    ],
    "nonbinary": [
      "{{flavor.colors.yellow.hex}}",
      "{{if(cond=flavor.light, t=flavor.colors.crust.hex, f=flavor.colors.text.hex)}}",
      "{{flavor.colors.mauve.hex}}",
      "{{if(cond=flavor.light, t=flavor.colors.text.hex, f=flavor.colors.crust.hex)}}"
    ],
    "rainbow": [
      "{{flavor.colors.red.hex}}",
      "{{flavor.colors.peach.hex}}",
      "{{flavor.colors.yellow.hex}}",
      "{{flavor.colors.green.hex}}",
      "{{flavor.colors.sky.hex}}",
      "{{flavor.colors.blue.hex}}"
    ],
    "transgender": [
      "{{flavor.colors.sapphire.hex}}",
      "{{if(cond=flavor.light, t=flavor.colors.rosewater.hex, f=flavor.colors.maroon.hex)}}",
      "{{if(cond=flavor.light, t=flavor.colors.crust.hex, f=flavor.colors.rosewater.hex)}}",
      "{{if(cond=flavor.light, t=flavor.colors.rosewater.hex, f=flavor.colors.maroon.hex)}}",
      "{{flavor.colors.sapphire.hex}}"
    ]
  }{% if not loop.last %},{% endif %}
  {%- endfor %}
}
