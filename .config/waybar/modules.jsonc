  "sway/window": {
    "format": "",
    "all-outputs": true,
    "format-alt": " {title}",
    "max-length": 80,
    "separate-outputs": false,
    "rewrite": {
      "^.*( — Zen Browser|Zen Browser)$":      " 󰈹 Zen",
      "^.*( — Firefox|Firefox)$":              " 󰈹 Firefox",
      "^.*( — Thunderbird|Thunderbird)$":      "  Thunderbird",
      "^.*( — Brave|Brave)$":                  " Brave",
      "^.*( — Chromium|Chromium)$":            "󰈹 Chromium",
      "^.*v( .*|$)":                           "  Neovim",
      "^.*(nvim).*$":                          "  Neovim",
