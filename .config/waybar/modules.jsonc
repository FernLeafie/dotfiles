      "8":  "е…«", 
      "9":  "д№қ",
      "10": "еҚҒ"
      */
    }
  },

  "clock": {
    "format": "{:%H:%M}",
    "timezones": [ "", "Asia/Tokyo" ],
    "format-alt": "{:%A %d.%m}",
    "tooltip-format": "<tt><big>{calendar}</big></tt>",
    "calendar": {
      "mode": "month",
      // "on-scroll": 1,
      "format": {
        "months":   "<span color='#f9e2af'><b>{}</b></span>",
        "days":     "<span color='#cdd6f4'><b>{}</b></span>",
        "weeks":    "<span color='#94e2d5'><b>W{}</b></span>",
        "weekdays": "<span color='#fab387'><b>{}</b></span>",
        "today":    "<span color='#f38ba8'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up":   "shift_up",
      "on-scroll-down": "shift_down",
      "on-click-middle": "tz_up"
    }
  },

/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ MAIN GROUPS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */

  "group/info": {
    "orientation": "inherit",
    "drawer": { "transition-duration": 300, "transition-left-to-right": true },
    "modules": [
      "custom/arrow-left",
      //"custom/playerlabel",
      "mpris",
      "custom/updates"
    ]
  },

  "group/apps": {
    "orientation": "inherit",
    "drawer": { "transition-duration": 300, "transition-left-to-right": true },
    "modules": [
      "custom/arrow-right",
      //"wlr/taskbar",
      "cpu",
      "memory",
      "disk"
    ]
  },

  "group/video": {
    "orientation": "inherit",
    "drawer": { "transition-duration": 300, "transition-left-to-right": false },
    "modules": [
      "custom/arrow-left",
      "custom/record",
      "custom/section",
      "custom/stop",
      "group/control-center"
    ]
  },

  "group/control-center": {
    "orientation": "inherit",
    "modules": [ "backlight", "custom/brightness", "group/audio", "group/connection"]
  },

  "group/audio": {
    "orientation": "inherit",
    "drawer": { "transition-duration": 300, "transition-left-to-right": false },
    "modules": ["pulseaudio"] // "custom/backlight", "pulseaudio/slider"
  },

  "group/connection": {
    "orientation": "inherit",
    "modules": ["group/network"]
  },

  "group/network": {
    "orientation": "inherit",
    "drawer": { "transition-duration": 10000, "transition-left-to-right": true },
    "modules": ["network"]
  },

  "group/bluetooth": {
    "orientation": "inherit",
    "drawer": { "transition-duration": 300, "transition-left-to-right": true },
    "modules": ["bluetooth", "bluetooth#status"]
  },

  "group/utils": {
    "orientation": "inherit",
    "drawer": { "transition-duration": 300, "transition-left-to-right": false },
    "modules": [
      "custom/arrow-right",
      "tray",
      "custom/notifications",
      "custom/weather"
    ]
  },

  "group/power":  {
    "orientation": "inherit",
    "drawer": { "transition-duration": 300, "transition-left-to-right": false },
    "modules": ["battery", "power-profiles-daemon"] //, "custom/power", "custom/quit", "custom/lock", "custom/reboot"
  },

/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ SYSTEM MODULES в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */

  "cpu":    { "format": "у°ҳҡ {usage}уұүё" },
  "memory": { "format": "пҲҖ {:2}уұүё" },
  "disk":   { "interval": 600, "format": "у°Ҷј {percentage_used}уұүё", "path": "/home/" },

  "battery": {
    "states": { "good": 95, "warning": 30, "critical": 15 },
    "format": "{icon}",
    "format-charging": "<b>{icon}оҖҠ</b>",
    "format-full": "<span color='#82A55F'><b>{icon}</b></span>",
    "format-icons": ["пү„","пүғ","пүӮ","пүҒ","пүҖ"],
    "tooltip-format": "{timeTo} {capacity} % | {power} W"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "scroll-step": 5,
    "max-volume": 100,
    "format-bluetooth": "{icon}",
    "format-muted": "у°–Ғ",
    "tooltip": false,
    "format-icons": {
      "headphones": "у°ӢҢ","handsfree": "у°ӢҢ","headset": "у°ӢҢ",
      "phone":      "пӮ•","portable": "пӮ•","car": "пҶ№ ",
      "default": ["у°•ҝ","у°–Җ","у°•ҫ"]
    },
    "on-click":         "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-middle":  "pavucontrol",
    "on-scroll-up":     "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down":   "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "smooth-scrolling-threshold": 1
  },

  "network": {
    "format": "{icon} {bandwidthDownBits}",
    "format-icons": { "wifi": ["у°ӨЁ"], "ethernet": ["у°ҲҒ"], "disconnected": ["о«җ"] },
    "format-wifi": "у°ӨЁ",
    "format-ethernet": "у°ҲҖ",
    "format-disconnected": "у°–Ә",
    "interval": 5,
    "tooltip": true,
    "tooltip-format": "{ipaddr}",
    "tooltip-format-wifi":      "{essid} ({signalStrength}%) пҮ«\n{ipaddr} | {frequency}В MHz{icon}\n{bandwidthDownBits} пҗү\n{bandwidthUpBits} пҗҠ",
    "tooltip-format-ethernet":  "{ifname} у°ҲҖ\n{ipaddr} | {frequency}В MHz{icon}\n{bandwidthDownBits} пҗү\n{bandwidthUpBits} пҗҠ",
    "tooltip-format-disconnected": "Not Connected to any type of Network",
    "on-click": "python ~/.config/rofi/network/network.py"
  },

  "network#speed": {
    "format": "{bandwidthDownBits} ",
    "interval": 5,
    "tooltip": false
  },

  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"]
  },

  "bluetooth": {
    "format":"пҠ”",
    "format-on": "пҠ”",
    "format-off": "у°ӮІ",
    "format-disabled": "",
    "format-connected": "пҠ“",
    "tooltip": false,
    "on-click": "bash ~/.config/rofi/bluetooth/bluetooth.sh"
  },

  "bluetooth#status": {
    "format-connected":             "<b>{num_connections}</b>",
    "format-connected-battery":     "<small><b>{device_battery_percentage}%</b></small>",
    "tooltip-format":               "{controller_alias} {controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected":     "{controller_alias} {controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected":           "{device_alias} {device_address}",
    "tooltip-format-enumerate-connected-battery":   "{device_alias} {device_address} {device_battery_percentage}%",
    "on-click": "rofi-bluetooth -config ~/.config/rofi/menu.d/network.rasi -i"
  },
  "mpris": {
    "interval": 5,
    "format": "{status_icon} {title}",
    "max-length": 50,
    "tooltip-format": "{dynamic}",
    "dynamic-order": ["player_icon", "title", "artist", "album", "position", "length"],
    "player-icons": {
      "spoyify": "пҶј",
      "plasma-browser-integration": "у°Ҳ№",
      "mpd": "пҖҒ"
    },
    "status-icons": {
		  "paused": "пҒҢ",
      "playing": "пҖҒ",
      "stopped": "пҒҚ"
    }
  },

/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ CUSTOM MODULES в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */

  //"custom/arrow-left":  { "format": "у°Ғ’", "tooltip": false },
  //"custom/arrow-right": { "format": "у°Ғҷ", "tooltip": false },

  "custom/arrow-left":  { "format": "&lt;", "tooltip": false },
  "custom/arrow-right": { "format": ">", "tooltip": false },

  "custom/updates": {
    "format": "уұ§• {}",
    "tooltip": true,
    "interval": 43200,               // 12В h
    "exec": "~/.config/hypr/scripts/check_updates.sh",
    "return-type": "json"
  },

  "custom/playerlabel": {
    "format": "пҖҒ {}",
    "max-length": 50,
    "interval": 5,
    "exec": "playerctl metadata --format='{{ title }}' -s",
    "on-click": "playerctl play-pause",
    // "on-scroll-up":     "playerctld shift",
    // "on-scroll-down":   "playerctld unshift",
    // "return-type": "json",
    // "exec": "~/.config/hypr/scripts/playerinfo.sh",
    // "exec": "playerctl metadata --format '{\"text\": \"{{artist}} : {{markup_escape(title)}}\", \"tooltip\": \"Spotify : {{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
    // "on-click":        "bash -c 'player=$(playerctl -l | grep -E \"spotify|cider\" | head -n 1); playerctl -p \"$player\" previous'",
    // "on-click-middle": "bash -c 'player=$(playerctl -l | grep -E \"spotify|cider\" | head -n 1); playerctl -p \"$player\" play-pause'",
    // "on-click-right":  "bash -c 'player=$(playerctl -l | grep -E \"spotify|cider\" | head -n 1); playerctl -p \"$player\" next'",
    "tooltip": false
  },

  "custom/record": {
    "format": "пҖҪ",
    "tooltip": true,
    "tooltip-format": "Record Screen",
    "on-click": "bash ~/.config/hypr/scripts/record.sh fullscreen"
  },
  "custom/stop": {
    "format": "у°»ғ",
    "tooltip": true,
    "tooltip-format": "Stop Recording",
    "on-click": "bash ~/.config/hypr/scripts/record.sh stop"
  },
  "custom/section": {
    "format": "п”¬",
    "tooltip": true,
    "tooltip-format": "Record Section",
    "on-click": "bash ~/.config/hypr/scripts/record.sh section"
  },

  "custom/notifications": {
    "format": "{} {icon}",
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click":       "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
    "tooltip": false,
    "format-icons": {
      "notification":                "уұ…«",
      "dnd-notification":            "у°Ӯӣ",
      "none":                        "у°Ӯҡ",
      "dnd-none":                    "у°Ӯӣ",
      "inhibited-notification":      "у°Ӯҡ",
      "inhibited-none":              "у°Ӯҡ",
      "dnd-inhibited-notification":  "у°Ӯӣ",
      "dnd-inhibited-none":          "у°Ӯӣ"
    }
  },

  "custom/weather": {
    "format": "{}",
    "tooltip": true,
    "interval": 3600,
    "exec": "wttrbar --hide-conditions --nerd --custom-indicator '{ICON} {temp_C}В°C'",
    "return-type": "json"
  },

  /*"custom/backlight": {
    "format": "{}% {icon}",
    "exec": "ddcutil getvcp 10 --brief",
    "rewrite": {
      "VCP 10 C (.2) 100": "$1"
    },
    "on-scroll-up": "ddcutil setvcp 10 + 10 --dis=1 && ddcutil setvcp 10 + 10 --dis=2 &",
    "on-scroll-down": "ddcutil setvcp 10 - 10 --dis=1 && ddcutil setvcp 10 - 10 --dis=2 &",
    "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"]
  },*/

  "custom/brightness": {
    "format": "{icon} {percentage}%",
    "format-icons": ["у°ғһ", "у°ғҹ", "у°ғ "], //["\uDB80\uDCDE", "\uDB80\uDCDF", "\uDB80\uDCE0"], ["у°ғһ", "у°ғҹ", "у°ғ "], ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"]
    "return-type": "json",
    "exec": "ddcutil --bus 5 getvcp 10 | grep -oP 'current.*?=\\s*\\K[0-9]+' | { read x; echo '{\"percentage\":'${x}'}'; }",
    "on-scroll-up": "ddcutil --noverify --bus 5 setvcp 10 + 10 && ddcutil --noverify --bus 6 setvcp 10 + 10",
    "on-scroll-down": "ddcutil --noverify --bus 5 setvcp 10 - 10 && ddcutil --noverify --bus 6 setvcp 10 - 10",
    "on-click": "ddcutil --noverify --bus 5 setvcp 10 0 && ddcutil --noverify --bus 6 setvcp 10 0",
    "on-click-right": "ddcutil --noverify --bus 5 setvcp 10 100 && ddcutil --noverify --bus 6 setvcp 10 100",
    "interval": 1,
    "tooltip": false
  },

  /*"custom/ddcutil": {
    "format": "{percentage}% {icon}",
    "interval": 1,
    "format-icons": ["п—ӣ", "п—ҡ", "п—ҷ"],
    "exec": "~/.config/waybar/waybar-ddcutil.py",
    "return-type": "json"
    }, */

  "custom/theme-switcher": {
    "format": "у°Ҹҳ",
    "tooltip": false,
    "on-click": "~/.config/hypr/scripts/toggle_theme.sh"
  },

  "custom/cava": {
    "format": "{}",
    "exec": "bash ~/.config/hypr/scripts/cava.sh"
  },

  "custom/icon": { "format": "у°ЈҮ" },

  "custom/quit": {
    "format": "у°—ј",
    "tooltip": false,
    "on-click": "hyprctl dispatch exit"
  },
  "custom/lock": {
    "format": "у°ҚҒ",
    "tooltip": false,
    "on-click": "swaylock"
  },
  "custom/reboot": {
    "format": "у°ңү",
    "tooltip": false,
    "on-click": "reboot"
  },
  "custom/power": {
    "format": "пҖ‘",
    "tooltip": false,
    "on-click": "shutdown now"
  },

/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ TASKBAR AND POWER PROFILES в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 20,
    "all-outputs": true,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": ["wofi", "rofi", "swaylock"]
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip": true,
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "format-icons": {
      "default":     "пғ§",
      "balanced":    "<span><small>пүҺ</small></span>",
      "power-saver": "<span color='#a6e3a1'><small>пҒ¬</small></span>"
    }
  },

  "tray": { "spacing": 8 }
}

