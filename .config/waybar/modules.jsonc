/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ CORE в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */

{
  "hyprland/window": {
    "format": "пҢғ",

    "format-alt": "пҢғ {title}",
    "max-length": 80,
    "separate-outputs": false,
    "on-click-right": "bash ~/.config/rofi/powermenu/powermenu.sh",
    "rewrite": {
      "^.*( вҖ” Zen Browser|Zen Browser)$":      "пҢғ у°Ҳ№ Zen",
      "^.*( вҖ” Firefox|Firefox)$":              "пҢғ у°Ҳ№ Firefox",
      "^.*( вҖ” Thunderbird|Thunderbird)$":      "пҢғ пҚ° Thunderbird",
      "^.*( вҖ” Brave|Brave)$":                  "пүЁ Brave",
      "^.*( вҖ” Chromium|Chromium)$":            "у°Ҳ№ Chromium",
      "^.*v( .*|$)":                           "пҢғ пҚҜ Neovim",
      "^.*(nvim).*$":                          "пҢғ пҚҜ Neovim",
      "^.*~$":                                 "пҢғ у°„ӣ Kitty",
      "^.*(- Spotify|Spotify)$":               "пҢғ пҶј Spotify",
      "^.*(- Code|Code)$":                     "пҢғ оЈҡ VSCode",
      "пҢғ (.*) - Thunar":                       "пҢғ пҒ» Thunar - $1",
      "пҢғ (.*) вҖ” Dolphin":                      "пҢғ пҒ» Dolphin - $1",
      "пҢғ (.*) - Discord":                      "пҢғ пҮҝ Discord - $1",
      "пҢғ .* - (.*) - Obsidian.*":              "пҢғ уұүҪ Obsidian - $1", 
      "пҢғ (btop)":                              "пҢғ у°“… btop",
      "пҢғ (rmpc).*":                            "пҢғ пҖҒ rmpc",
      "пҢғ (cava).*":                            "пҢғ пҖҒ cava",
      "пҢғ (waybar)":                            "пҢғ оҜІ waybar",
      "пҢғ (yazi).*":                            "пҢғ у°ҮҘ yazi",
      "пҢғ Gitkraken Desktop":                   "пҢғ пҠ¬ GitKraken",
      "пҢғ .*(Manga Reader)":                    "пҢғ у°Ӯә Manga Reader",
      "пҢғ (Krita)":                             "пҢғ пҢҪ Krita",
      "пҢғ (.*) - Inkscape":                     "пҢғ пҢ» Inkscape - $1",
      "пҢғ (.*) - Aseprite .*":                  "пҢғ о№ө Aseprite - $1",
      "пҢғ (.*) вҖ” LibreOffice Writer":           "пҢғ пҚј LibreOffice Writer - $1",

      // Games
      "(пҢғ Steam)":                             "пҢғ пҶ¶ Steam",
      "(пҢғ Minecraft).*":                       "пҢғ у°Қі Minecraft",
      "пҢғ (Prism Launcher).*":                  "пҢғ у°Ҷ§ Prism",
      "пҢғ (Stardew Valley).*":                  "пҢғ оҠҹ Stardew Valley",
      "пҢғ (SMAPI).*":                           "пҢғ оҠҹ SMAPI",
      "пҢғ (Lutris)":                            "пҢғ ојҠ Lutris",
      "^.*(- Cursor|Cursor)$":                 "у°Ҳ№ Cursor"
      /*"^.+ $":                                 "о«Ө Empty"   // avoid empty titles*/
    }
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "all-outputs": true,
    "format-icons": {
      /*
      "1":  "оҜҠ",  
      "2":  "у°–ҹ", 
      "3":  "у°…©", 
      "4":  "у°һ¶", 
      "5":  "оҲ—",
      "6":  "у°“Ү", 
      "7":  "оӘӨ", 
      "8":  "у°•§", 
      "9":  "о©ә", 
      "10": "у°ҷҜ"
      
