      "3":  "у°Ҡ ", 
      "4":  "у°Ҡ ", 
      "5":  "у°Ҡ ",
      "6":  "у°Ҡ ", 
      "7":  "у°Ҡ ", 
      "8":  "у°Ҡ ", 
      "9":  "у°Ҡ ", 
      "10": "у°Ҡ "
