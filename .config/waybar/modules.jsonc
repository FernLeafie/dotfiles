      "^.*(- Spotify|Spotify)$":               "  Spotify",
      "^.*(- Code|Code)$":                     "  VSCode",
      " (.*) - Thunar":                       "  Thunar - $1",
      " (.*) — Dolphin":                      "  Dolphin - $1",
      " (.*) - Discord":                      "  Discord - $1",
      " .* - (.*) - Obsidian.*":              " 󱉽 Obsidian - $1", 
