      "( Minecraft).*":                       " 󰍳 Minecraft",
      " (Prism Launcher).*":                  " 󰆧 Prism",
      " (Stardew Valley).*":                  "  Stardew Valley",
      " (SMAPI).*":                           "  SMAPI",
      " (Steins;Gate)":                       "  Steins;Gate",
      " (Spiritfarer)":                       " 󰻈 Spiritfarer",
      " (Potion Craft)":                      " 󰙛 Potion Craft",
      ". (Portal - ).*":                       " 󰃫 Portal",
      ". (PORTAL 2 - ).*":                     " 󰃫 Portal 2",
      ". (Portal Stories: Mel - ).*":          " 󰃫 Portal Stories: Mel",
      ". (Celeste)":                           " 󰋵 Celeste",
      " (Raft)":                              " 󱙳 Raft",
      " (ASTRONEER  )":                       " 󰹛 Astroneer",
      " (SIGNALIS)":                          " 󰔷 Signalis",
      " (Lutris)":                            "  Lutris",
      "^.*(- Cursor|Cursor)$":                 "󰈹 Cursor"
