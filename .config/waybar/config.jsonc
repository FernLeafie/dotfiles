{
    "layer": "bottom",
    "position": "top",
    "margin": "4 500 0 500",
    "fixed-center": true,
    "reload_style_on_change": true,
    "name": "overlay",
    "passtrough": true,

    "include": ["~/.config/waybar/modules.jsonc"],

    "modules-left": [
      "sway/window",
      "hyprland/window",
      "group/apps"
      
    ],
    
    "modules-center": [
      "group/info",
      "sway/workspaces",
      "hyprland/workspaces",
      "group/utils"
      
    ],
  
    "modules-right": [
      "group/video",
      "clock",
      "group/power"
    ]
  }
  
